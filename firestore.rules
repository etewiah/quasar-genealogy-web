rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Tree metadata — public read
    match /trees/{treeId} {
      allow read: if true;
      allow write: if false;
    }

    // Individuals — public read (privacy enforcement handled at the app layer)
    match /trees/{treeId}/individuals/{indiId} {
      allow read: if true;
      allow write: if false;
    }

    // Families — public read
    match /trees/{treeId}/families/{famId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
