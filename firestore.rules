rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Tree metadata — public read, authenticated write
    match /trees/{treeId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Individuals — public read, authenticated write
    match /trees/{treeId}/individuals/{indiId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Families — public read, authenticated write
    match /trees/{treeId}/families/{famId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
